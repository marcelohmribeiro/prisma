    <!-- Delete Account Success Modal -->
    <div id="deleteModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm hidden items-center justify-center z-50" style="display: none;">
        <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl p-12 max-w-md w-full mx-4 shadow-2xl border border-red-900/50 text-center">
            <div class="mb-6">
                <i class="fas fa-trash-alt text-red-500 text-5xl"></i>
            </div>
            <h2 class="text-3xl font-bold text-white mb-4">Conta Exclu√≠da com Sucesso!</h2>
            <p class="text-gray-300 mb-3">Sua conta foi permanentemente removida.</p>
            <p class="text-gray-400 text-sm mb-8">Todos os seus dados, conquistas e progresso foram apagados.</p>
            <button onclick="confirmDelete()" class="w-full py-4 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-bold text-lg rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg">
                Sair
            </button>
        </div>
    </div>

    <script>
        // Platform trophy statistics (percentages)
        // Total must equal 100%
        // Percentages control the intensity/opacity of each light beam
        const platformStats = {
            playstation: { percentage: 20, color: '#0070CC', name: 'PlayStation' },
            xbox: { percentage: 10, color: '#107C10', name: 'Xbox' },
            steam: { percentage: 60, color: '#66c0f4', name: 'Steam' },
            retroachievements: { percentage: 10, color: '#D4A017', name: 'RetroAchievements' }
        };

        // Generate dynamic prisma effect based on platform percentages
        function generatePrismaEffect() {
            const beams = {
                'beam-playstation': platformStats.playstation,
                'beam-xbox': platformStats.xbox,
                'beam-steam': platformStats.steam,
                'beam-retro': platformStats.retroachievements
            };

            Object.entries(beams).forEach(([className, platform]) => {
                const beam = document.querySelector(`.${className}`);
                if (beam) {
                    // Calculate opacity based on percentage (10% = 0.2, 60% = 0.6, etc)
                    const baseOpacity = platform.percentage / 100;
                    beam.style.opacity = baseOpacity;
                }
            });

            // Update prisma core with mixed colors
            const core = document.querySelector('.prisma-core');
            if (core) {
                // Create dynamic radial gradient based on strongest platforms
                const sortedPlatforms = Object.values(platformStats)
                    .sort((a, b) => b.percentage - a.percentage);
                
                const gradientStops = sortedPlatforms.map((platform, index) => {
                    const opacity = (platform.percentage / 100) * 0.2;
                    return `${platform.color}${Math.floor(opacity * 255).toString(16).padStart(2, '0')} ${index * 25}%`;
                }).join(', ');
            }
        }

        // Apply prisma effect on load
        window.addEventListener('load', () => {
            generatePrismaEffect();
            createPrismaParticles();
        });

        // Create floating particles based on platform colors
        function createPrismaParticles() {
            const prismaBackground = document.querySelector('.prisma-background');
            const platforms = Object.values(platformStats);
            
            // Create particles proportional to platform percentage
            platforms.forEach(platform => {
                const particleCount = Math.floor(platform.percentage / 5); // 60% = 12 particles, 10% = 2 particles
                
                for (let i = 0; i < particleCount; i++) {
                    const particle = document.createElement('div');
                    particle.className = 'prisma-particle';
                    particle.style.backgroundColor = platform.color;
                    particle.style.left = Math.random() * 100 + '%';
                    particle.style.animationDuration = (Math.random() * 15 + 10) + 's';
                    particle.style.animationDelay = Math.random() * 5 + 's';
                    particle.style.boxShadow = `0 0 10px ${platform.color}`;
                    
                    prismaBackground.appendChild(particle);
                }
            });
        }

        // Add smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Sidebar navigation
        const sidebarIcons = document.querySelectorAll('.sidebar-icon');
        const pages = {
            dashboard: document.querySelector('.dashboard-page'),
            settings: document.querySelector('.settings-page'),
            followers: document.querySelector('.followers-page')
        };

        sidebarIcons.forEach(icon => {
            icon.addEventListener('click', function() {
                const page = this.getAttribute('data-page');
                
                // Handle ranking page redirect
                if (page === 'ranking') {
                    window.location.href = 'ranking.html';
                    return;
                }
                
                if (page && pages[page]) {
                    // Remove active from all icons
                    sidebarIcons.forEach(i => i.classList.remove('active'));
                    
                    // Add active to clicked icon
                    this.classList.add('active');
                    
                    // Hide all pages
                    Object.values(pages).forEach(p => p.classList.remove('active'));
                    
                    // Show selected page
                    pages[page].classList.add('active');
                    
                    // Update icon colors
                    sidebarIcons.forEach(i => {
                        const iconElement = i.querySelector('i');
                        if (i.classList.contains('active')) {
                            iconElement.classList.remove('text-gray-400');
                            iconElement.classList.add('text-blue-400');
                        } else {
                            iconElement.classList.remove('text-blue-400');
                            iconElement.classList.add('text-gray-400');
                        }
                    });
                }
            });
        });

        // Logout button functionality
        const logoutBtn = document.querySelector('.btn-logout');
        if (logoutBtn) {
            logoutBtn.addEventListener('click', function() {
                // Show logout modal
                const logoutModal = document.getElementById('logoutModal');
                logoutModal.style.display = 'flex';
            });
        }

        // Confirm logout and redirect
        window.confirmLogout = function() {
            window.location.href = 'index.html';
        };

        // Delete account button functionality
        const deleteBtn = document.querySelector('.btn-delete');
        if (deleteBtn) {
            deleteBtn.addEventListener('click', function() {
                // Show delete confirmation modal
                const deleteConfirmModal = document.getElementById('deleteConfirmModal');
                deleteConfirmModal.style.display = 'flex';
                // Clear input
                document.getElementById('deleteConfirmInput').value = '';
            });
        }

        // Close delete confirmation modal
        window.closeDeleteConfirm = function() {
            const deleteConfirmModal = document.getElementById('deleteConfirmModal');
            deleteConfirmModal.style.display = 'none';
            document.getElementById('deleteConfirmInput').value = '';
        };

        // Process delete account
        window.processDelete = function() {
            const input = document.getElementById('deleteConfirmInput').value;
            if (input === 'EXCLUIR') {
                // Hide confirmation modal
                document.getElementById('deleteConfirmModal').style.display = 'none';
                // Show success modal
                const deleteModal = document.getElementById('deleteModal');
                deleteModal.style.display = 'flex';
            } else {
                alert('Confirma√ß√£o incorreta. Digite "EXCLUIR" para confirmar a exclus√£o.');
            }
        };

        // Confirm delete and redirect
        window.confirmDelete = function() {
            window.location.href = 'index.html';
        };

        // Followers tabs functionality
        const followersTabs = document.querySelectorAll('.followers-tab');
        const tabContents = document.querySelectorAll('.tab-content');

        followersTabs.forEach(tab => {
            tab.addEventListener('click', function() {
                const tabName = this.getAttribute('data-tab');
                
                // Remove active from all tabs
                followersTabs.forEach(t => t.classList.remove('active'));
                
                // Add active to clicked tab
                this.classList.add('active');
                
                // Hide all tab contents
                tabContents.forEach(content => content.classList.remove('active'));
                
                // Show selected tab content
                const targetContent = document.getElementById(tabName);
                if (targetContent) {
                    targetContent.classList.add('active');
                }

                // Update page title based on tab
                const followersHeader = document.querySelector('.followers-header h1');
                if (followersHeader) {
                    if (tabName === 'seguidores') {
                        followersHeader.textContent = 'Seguidores (12)';
                    } else if (tabName === 'seguindo') {
                        followersHeader.textContent = 'Seguindo (5)';
                    } else if (tabName === 'pesquisar') {
                        followersHeader.textContent = 'Pesquisar Pessoas';
                    }
                }
            });
        });

        // Open profile page when clicking on follower card
        document.addEventListener('click', function(e) {
            const followerCard = e.target.closest('.follower-card');
            
            // Se clicar no card mas n√£o no bot√£o de seguir
            if (followerCard && !e.target.classList.contains('btn-follow')) {
                const username = followerCard.querySelector('.follower-username').textContent.replace('@', '');
                window.location.href = `profile.html?user=${username}`;
                return;
            }
        });

        // Follow/Unfollow button functionality
        document.addEventListener('click', function(e) {
            if (e.target.classList.contains('btn-follow')) {
                e.stopPropagation(); // Previne a abertura do perfil
                
                const followingCountElement = document.getElementById('followingCount');
                let currentCount = parseInt(followingCountElement.textContent);
                const followerCard = e.target.closest('.follower-card');
                const username = followerCard.querySelector('.follower-username').textContent.replace('@', '').toLowerCase();
                
                // Gerenciar localStorage de following
                let following = JSON.parse(localStorage.getItem('following') || '[]');
                
                console.log('Dashboard - Toggle follow for:', username);
                console.log('Current following list:', following);
                
                if (e.target.classList.contains('following')) {
                    // Deixar de seguir
                    e.target.classList.remove('following');
                    e.target.textContent = 'Seguir';
                    
                    // Remover do localStorage
                    following = following.filter(user => user !== username);
                    localStorage.setItem('following', JSON.stringify(following));
                    
                    console.log('Unfollowed. New list:', following);
                    
                    // Atualizar contador
                    currentCount--;
                    followingCountElement.textContent = currentCount;
                    
                    // Atualizar t√≠tulo da aba "Seguindo"
                    const followersHeader = document.querySelector('.followers-header h1');
                    const activeTab = document.querySelector('.followers-tab.active');
                    if (activeTab && activeTab.getAttribute('data-tab') === 'seguindo') {
                        followersHeader.textContent = `Seguindo (${currentCount})`;
                    }
                } else {
                    // Seguir
                    e.target.classList.add('following');
                    e.target.textContent = '';
                    
                    // Adicionar ao localStorage
                    if (!following.includes(username)) {
                        following.push(username);
                        localStorage.setItem('following', JSON.stringify(following));
                    }
                    
                    console.log('Followed. New list:', following);
                    
                    // Atualizar contador
                    currentCount++;
                    followingCountElement.textContent = currentCount;
                    
                    // Atualizar t√≠tulo da aba "Seguindo"
                    const followersHeader = document.querySelector('.followers-header h1');
                    const activeTab = document.querySelector('.followers-tab.active');
                    if (activeTab && activeTab.getAttribute('data-tab') === 'seguindo') {
                        followersHeader.textContent = `Seguindo (${currentCount})`;
                    }
                }
            }
        });

        // Search functionality
        const searchInput = document.querySelector('.search-input');
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                const searchTerm = e.target.value.toLowerCase();
                const followerCards = document.querySelectorAll('#pesquisar .follower-card');
                
                followerCards.forEach(card => {
                    const name = card.querySelector('.follower-name').textContent.toLowerCase();
                    const username = card.querySelector('.follower-username').textContent.toLowerCase();
                    
                    if (name.includes(searchTerm) || username.includes(searchTerm)) {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        }

        // Animate progress bars on load
        window.addEventListener('load', () => {
            const progressBars = document.querySelectorAll('.progress-fill');
            progressBars.forEach(bar => {
                const width = bar.style.width;
                bar.style.width = '0%';
                setTimeout(() => {
                    bar.style.width = width;
                }, 100);
            });
        });

        // Achievement stars interactive
        const stars = document.querySelectorAll('.achievement-star');
        stars.forEach((star, index) => {
            star.addEventListener('mouseenter', () => {
                for (let i = 0; i <= index; i++) {
                    stars[i].style.color = '#fbbf24';
                }
            });
        });

        const achievementContainer = stars[0]?.parentElement;
        if (achievementContainer) {
            achievementContainer.addEventListener('mouseleave', () => {
                stars.forEach(star => {
                    star.style.color = '#9ca3af';
                });
            });
        }

        // Achievement Modal Functions
        window.openAchievementModal = function(element, e) {
            console.log('openAchievementModal called', element);
            if (e) {
                e.stopPropagation();
            }
            
            try {
                const data = JSON.parse(element.getAttribute('data-achievement'));
                const modal = document.getElementById('achievementModal');
                
                if (!modal) {
                    console.error('Modal not found!');
                    return;
                }
                
                console.log('Modal element:', modal);
                console.log('Achievement data:', data);
                
                const modalIcon = document.getElementById('modalIcon');
                const modalTitle = document.getElementById('modalTitle');
                const modalGame = document.getElementById('modalGame');
                const modalRarity = document.getElementById('modalRarity');
                const modalDescription = document.getElementById('modalDescription');
                const modalImage = document.getElementById('modalImage');
                
                console.log('Modal elements found:', {modalIcon, modalTitle, modalGame, modalRarity, modalDescription, modalImage});
                
                if (!modalIcon || !modalTitle || !modalGame || !modalRarity || !modalDescription || !modalImage) {
                    console.error('Some modal elements not found!');
                    return;
                }
                
                modalIcon.textContent = data.icon;
                modalTitle.textContent = data.name;
                modalGame.textContent = data.game;
                
                // Define a classe de raridade baseada na porcentagem
                let rarityClass = 'rarity-common';
                let rarityLabel = 'Comum';
                
                if (data.percentage >= 50) {
                    rarityClass = 'rarity-common';
                    rarityLabel = 'Comum';
                } else if (data.percentage >= 20) {
                    rarityClass = 'rarity-uncommon';
                    rarityLabel = 'Incomum';
                } else if (data.percentage >= 10) {
                    rarityClass = 'rarity-rare';
                    rarityLabel = 'Raro';
                } else if (data.percentage >= 5) {
                    rarityClass = 'rarity-epic';
                    rarityLabel = '√âpico';
                } else {
                    rarityClass = 'rarity-legendary';
                    rarityLabel = 'Lend√°rio';
                }
                
                modalRarity.className = `rarity-badge ${rarityClass}`;
                modalRarity.innerHTML = `<span>${rarityLabel}</span><span class="rarity-percentage">${data.percentage}%</span>`;
                
                modalDescription.textContent = data.description;
                modalImage.src = data.image;
                
                console.log('Adding active class to modal');
                modal.classList.add('active');
                document.body.style.overflow = 'hidden';
                console.log('Modal classes:', modal.className);
            } catch (error) {
                console.error('Error opening modal:', error);
            }
        }

        window.closeAchievementModal = function(e) {
            console.log('closeAchievementModal called');
            if (e) {
                e.stopPropagation();
                e.preventDefault();
            }
            const modal = document.getElementById('achievementModal');
            if (modal) {
                console.log('Removing active class from modal');
                modal.classList.remove('active');
                document.body.style.overflow = '';
                console.log('Modal classes after close:', modal.className);
            }
        }

        // Use event delegation on document for achievement cards
        document.addEventListener('click', function(e) {
            console.log('Document click:', e.target);
            
            // Check if clicked element or its parent is a pinned-achievement (not in modal)
            const achievementCard = e.target.closest('.pinned-achievement');
            if (achievementCard && achievementCard.hasAttribute('data-achievement') && !e.target.closest('#pinModal')) {
                console.log('Achievement card clicked!');
                e.stopPropagation();
                e.preventDefault();
                window.openAchievementModal(achievementCard, e);
                return;
            }

            // Check if clicked on modal background
            if (e.target.id === 'achievementModal') {
                console.log('Modal background clicked');
                window.closeAchievementModal(e);
                return;
            }

            // Check if clicked on close button or its child (icon) for achievement modal
            const closeButton = e.target.closest('.modal-close');
            if (closeButton && !e.target.closest('#pinModal')) {
                console.log('Close button clicked');
                window.closeAchievementModal(e);
                return;
            }
        });

        // Close modal on ESC key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const modal = document.getElementById('achievementModal');
                if (modal && modal.classList.contains('active')) {
                    console.log('ESC key pressed');
                    window.closeAchievementModal(e);
                }
                
                const pinModal = document.getElementById('pinModal');
                if (pinModal && pinModal.classList.contains('active')) {
                    closePinModal();
                }
            }
        });

        // Pin Modal Functionality
        const allAchievements = [
            {name: "Primeira Vit√≥ria", desc: "Ven√ßa seu primeiro jogo.", icon: "‚≠ê", game: "Far Cry 6", percentage: "95.2"},
            {name: "Mestre da Espada", desc: "Derrote 100 inimigos com uma espada.", icon: "‚öîÔ∏è", game: "Dark Souls", percentage: "32.5"},
            {name: "Explorador Nato", desc: "Descubra todos os locais ocultos.", icon: "üåç", game: "Skyrim", percentage: "15.8"},
            {name: "Colecionador Lend√°rio", desc: "Adquira todos os itens lend√°rios.", icon: "üíé", game: "Diablo IV", percentage: "3.2"},
            {name: "Protetor da Cidade", desc: "Salve a cidade de uma amea√ßa.", icon: "üõ°Ô∏è", game: "Spider-Man", percentage: "67.9"},
            {name: "Ca√ßador de Tesouros", desc: "Encontre 50 tesouros escondidos.", icon: "üèÜ", game: "Uncharted 4", percentage: "24.1"},
            {name: "Artes√£o M√°gico", desc: "Crie 100 itens m√°gicos.", icon: "üîÆ", game: "Minecraft", percentage: "41.3"},
            {name: "Conflito Intenso", desc: "Complete 10 miss√µes de conflito em √°reas de alta tens√£o.", icon: "üéÆ", game: "Far Cry 6", percentage: "45.2"},
            {name: "Mochil√£o", desc: "Colete todos os itens de mochila espalhados pelo mapa.", icon: "üéí", game: "Far Cry 6", percentage: "78.5"},
            {name: "At√© N√£o Sobrar Nenhum", desc: "Elimine todos os inimigos em modo Realista+.", icon: "üíÄ", game: "TLOU II", percentage: "2.8"},
            {name: "Platina", desc: "Obtenha todas as conquistas do jogo.", icon: "üèÜ", game: "God of War", percentage: "8.3"},
            {name: "Velocista", desc: "Complete o jogo em menos de 2 horas.", icon: "‚ö°", game: "Celeste", percentage: "5.7"},
            {name: "Pacifista", desc: "Complete sem matar nenhum inimigo.", icon: "üíö", game: "Undertale", percentage: "12.4"},
            {name: "Mestre Chef", desc: "Prepare todas as receitas dispon√≠veis.", icon: "üë®‚Äçüç≥", game: "Overcooked", percentage: "18.9"},
        ];

        let selectedAchievements = [];
        const MAX_PINS = 4;

        function openPinModal() {
            const modal = document.getElementById('pinModal');
            const body = document.getElementById('pinModalBody');
            
            // Get currently pinned achievements
            const pinnedGrid = document.getElementById('pinnedGrid');
            const currentPinned = Array.from(pinnedGrid.querySelectorAll('.pinned-achievement')).map(el => {
                const data = JSON.parse(el.getAttribute('data-achievement'));
                return data.name;
            });
            
            selectedAchievements = [...currentPinned];
            
            renderAchievementList(allAchievements);
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closePinModal() {
            const modal = document.getElementById('pinModal');
            modal.classList.remove('active');
            document.body.style.overflow = '';
            document.getElementById('pinSearchInput').value = '';
        }

        function renderAchievementList(achievements) {
            const body = document.getElementById('pinModalBody');
            
            if (achievements.length === 0) {
                body.innerHTML = `
                    <div class="pin-achievement-empty">
                        <i class="fas fa-search"></i>
                        <p>Nenhuma conquista encontrada</p>
                    </div>
                `;
                return;
            }
            
            body.innerHTML = achievements.map(ach => {
                const isSelected = selectedAchievements.includes(ach.name);
                return `
                    <div class="pin-achievement-item ${isSelected ? 'selected' : ''}" data-name="${ach.name}">
                        <div class="pin-checkbox">
                            <i class="fas fa-check"></i>
                        </div>
                        <div class="pin-achievement-icon-wrapper">
                            ${ach.icon}
                        </div>
                        <div class="pin-achievement-info">
                            <div class="pin-achievement-title">${ach.name}</div>
                            <div class="pin-achievement-desc">${ach.desc}</div>
                        </div>
                    </div>
                `;
            }).join('');
            
            updateConfirmButton();
        }

        function updateConfirmButton() {
            const btn = document.getElementById('pinConfirmBtn');
            btn.disabled = selectedAchievements.length === 0;
        }

        // Setup event listeners after DOM loads
        window.addEventListener('load', function() {
            // Event delegation for achievement selection in pin modal
            const pinModalBody = document.getElementById('pinModalBody');
            if (pinModalBody) {
                pinModalBody.addEventListener('click', function(e) {
                    console.log('Pin modal body click:', e.target);
                    const item = e.target.closest('.pin-achievement-item');
                    if (item) {
                        console.log('Pin achievement item clicked:', item);
                        e.stopPropagation();
                        
                        const name = item.getAttribute('data-name');
                        const isSelected = selectedAchievements.includes(name);
                        
                        console.log('Achievement name:', name, 'Is selected:', isSelected);
                        
                        if (isSelected) {
                            selectedAchievements = selectedAchievements.filter(n => n !== name);
                            item.classList.remove('selected');
                        } else {
                            if (selectedAchievements.length < MAX_PINS) {
                                selectedAchievements.push(name);
                                item.classList.add('selected');
                            } else {
                                alert(`Voc√™ pode fixar no m√°ximo ${MAX_PINS} conquistas!`);
                            }
                        }
                        
                        console.log('Updated selected achievements:', selectedAchievements);
                        updateConfirmButton();
                    }
                });
            }

            // Search functionality
            const pinSearchInput = document.getElementById('pinSearchInput');
            if (pinSearchInput) {
                pinSearchInput.addEventListener('input', function(e) {
                    const search = e.target.value.toLowerCase();
                    const filtered = allAchievements.filter(ach => 
                        ach.name.toLowerCase().includes(search) || 
                        ach.desc.toLowerCase().includes(search) ||
                        ach.game.toLowerCase().includes(search)
                    );
                    renderAchievementList(filtered);
                });
            }
        });

        // Edit Profile Functions
        let currentAvatarUrl = 'https://api.dicebear.com/7.x/avataaars/svg?seed=Nolan&backgroundColor=b6e3f4';
        let currentFullName = 'Nolan Bateman';
        let currentNickname = 'nolan';

        window.openEditProfile = function() {
            const modal = document.getElementById('editProfileModal');
            const nicknameInput = document.getElementById('nicknameInput');
            const fullNameInput = document.getElementById('fullNameInput');
            const avatarPreview = document.getElementById('avatarPreview');
            
            // Load current data
            nicknameInput.value = currentNickname;
            fullNameInput.value = currentFullName;
            avatarPreview.src = currentAvatarUrl;
            
            modal.classList.add('active');
        };

        window.closeEditProfile = function() {
            const modal = document.getElementById('editProfileModal');
            modal.classList.remove('active');
        };

        window.handleAvatarChange = function(event) {
            const file = event.target.files[0];
            if (file) {
                // Check file size (max 2MB)
                if (file.size > 2 * 1024 * 1024) {
                    alert('A imagem deve ter no m√°ximo 2MB');
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(e) {
                    const avatarPreview = document.getElementById('avatarPreview');
                    avatarPreview.src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        };

        window.saveProfile = function() {
            const nicknameInput = document.getElementById('nicknameInput');
            const fullNameInput = document.getElementById('fullNameInput');
            const avatarPreview = document.getElementById('avatarPreview');
            const profileName = document.getElementById('profileName');
            const profileAvatar = document.getElementById('profileAvatar');
            
            // Convert nickname to lowercase and remove spaces
            let nickname = nicknameInput.value.trim().toLowerCase().replace(/\s+/g, '_');
            
            // Validate nickname - only letters, numbers, and underscore
            const nicknameRegex = /^[a-z0-9_]+$/;
            if (!nickname) {
                alert('Por favor, insira um nickname');
                return;
            }
            
            if (!nicknameRegex.test(nickname)) {
                alert('O nickname deve conter apenas letras min√∫sculas, n√∫meros e underscore (_)');
                return;
            }

            if (nickname.length < 3) {
                alert('O nickname deve ter pelo menos 3 caracteres');
                return;
            }

            if (!fullNameInput.value.trim()) {
                alert('Por favor, insira seu nome completo');
                return;
            }

            // Update profile - nickname with @ is displayed on dashboard
            profileName.textContent = '@' + nickname;
            profileAvatar.src = avatarPreview.src;
            currentAvatarUrl = avatarPreview.src;
            currentNickname = nickname;
            currentFullName = fullNameInput.value;
            
            // Update input to show formatted nickname
            nicknameInput.value = nickname;
            
            // Close modal
            closeEditProfile();
            
            // Show success message
            alert('Perfil atualizado com sucesso!');
        };

        // Close modal on backdrop click
        document.getElementById('editProfileModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeEditProfile();
            }
        });

        // Setup pin modal buttons after DOM is ready
        window.addEventListener('load', function() {
            const openBtn = document.getElementById('openPinModal');
            const cancelBtn = document.getElementById('pinCancelBtn');
            const confirmBtn = document.getElementById('pinConfirmBtn');
            const pinModal = document.getElementById('pinModal');
            
            console.log('Setting up pin modal buttons:', {openBtn, cancelBtn, confirmBtn, pinModal});
            
            if (openBtn) {
                openBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    console.log('Open pin modal clicked');
                    openPinModal();
                });
            }
            
            if (cancelBtn) {
                cancelBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    console.log('Cancel button clicked');
                    closePinModal();
                });
            }
            
            if (confirmBtn) {
                confirmBtn.addEventListener('click', function(e) {
                    console.log('Confirm button clicked');
                    console.log('Selected achievements:', selectedAchievements);
                    
                    e.stopPropagation();
                    e.preventDefault();
                    
                    const pinnedGrid = document.getElementById('pinnedGrid');
                    console.log('Pinned grid element:', pinnedGrid);
                    
                    if (!pinnedGrid) {
                        console.error('Pinned grid not found!');
                        return;
                    }
                    
                    const selectedData = allAchievements.filter(ach => selectedAchievements.includes(ach.name));
                    console.log('Selected data:', selectedData);
                    
                    pinnedGrid.innerHTML = selectedData.map(ach => {
                        const achievementData = {
                            name: ach.name,
                            game: ach.game,
                            percentage: ach.percentage,
                            rarity: ach.percentage >= 50 ? 'common' : ach.percentage >= 20 ? 'uncommon' : ach.percentage >= 10 ? 'rare' : ach.percentage >= 5 ? 'epic' : 'legendary',
                            description: ach.desc,
                            icon: ach.icon,
                            image: 'https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=500&h=300&fit=crop'
                        };
                        
                        return `
                            <div class="pinned-achievement" data-achievement='${JSON.stringify(achievementData)}'>
                                <div class="achievement-icon">${ach.icon}</div>
                                <div class="achievement-name">${ach.name}</div>
                                <div class="achievement-game">${ach.game}</div>
                            </div>
                        `;
                    }).join('');
                    
                    console.log('Grid updated, closing modal');
                    closePinModal();
                });
            }
            
            if (pinModal) {
                pinModal.addEventListener('click', function(e) {
                    if (e.target === this) {
                        closePinModal();
                    }
                });
            }
        });
    </script>

    <!-- Edit Profile Modal -->
    <div id="editProfileModal" class="edit-profile-modal">
        <div class="edit-profile-content">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-white">Editar Perfil</h2>
                <button onclick="closeEditProfile()" class="text-gray-400 hover:text-white transition-colors">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>

            <!-- Avatar Preview -->
            <div class="text-center mb-6">
                <img id="avatarPreview" src="https://api.dicebear.com/7.x/avataaars/svg?seed=Nolan&backgroundColor=b6e3f4" 
                     alt="Avatar Preview" 
                     class="avatar-preview">
            </div>

            <!-- Upload Photo -->
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-300 mb-2">Foto de Perfil</label>
                <div class="file-input-wrapper">
                    <input type="file" id="avatarInput" accept="image/*" onchange="handleAvatarChange(event)">
                    <label for="avatarInput" class="file-input-label">
                        <i class="fas fa-camera"></i>
                        Escolher Nova Foto
                    </label>
                </div>
                <p class="text-xs text-gray-500 mt-2">JPG, PNG ou GIF. M√°ximo 2MB.</p>
            </div>

            <!-- Nome Completo -->
            <div class="mb-4">
                <label class="block text-sm font-semibold text-gray-300 mb-2">Nome Completo</label>
                <input type="text" id="fullNameInput" class="form-input-profile" placeholder="Digite seu nome completo" value="Nolan Bateman">
            </div>

            <!-- Nickname -->
            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-300 mb-2">Nickname</label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 font-medium">@</span>
                    <input type="text" id="nicknameInput" class="form-input-profile pl-8" placeholder="digite_seu_nickname" value="nolan" style="text-transform: lowercase;">
                </div>
                <p class="text-xs text-gray-500 mt-1">Apenas letras min√∫sculas, n√∫meros e underscore. Este ser√° exibido no seu perfil</p>
            </div>

            <!-- Buttons -->
            <div class="flex gap-3">
                <button onclick="closeEditProfile()" class="flex-1 px-4 py-3 bg-transparent border border-gray-600 rounded-lg text-gray-300 font-semibold hover:bg-gray-800 transition-colors">
                    Cancelar
                </button>
                <button onclick="saveProfile()" class="flex-1 px-4 py-3 bg-gradient-to-r from-blue-500 to-blue-600 rounded-lg text-white font-semibold hover:shadow-lg transition-all">
                    Salvar Altera√ß√µes
                </button>
            </div>
        </div>
    </div>

    <!-- Achievement Modal -->
    <div id="achievementModal" class="achievement-modal">
        <div class="modal-content">
            <button class="modal-close">
                <i class="fas fa-times"></i>
            </button>
            
            <div class="modal-header">
                <div id="modalIcon" class="modal-icon">üèÜ</div>
                <div class="modal-title-section">
                    <h2 id="modalTitle">Nome da Conquista</h2>
                    <div id="modalGame" class="modal-game">Nome do Jogo</div>
                </div>
            </div>
            
            <div class="modal-body">
                <div class="modal-info-row">
                    <span class="modal-info-label">Raridade</span>
                    <span id="modalRarity" class="rarity-badge rarity-common">
                        <span>Comum</span>
                        <span id="modalPercentage" class="rarity-percentage">50%</span>
                    </span>
                </div>
                
                <div class="modal-description">
                    <p id="modalDescription">Descri√ß√£o da conquista aparece aqui com todos os detalhes necess√°rios.</p>
                </div>
                
                <img id="modalImage" src="" alt="Game Screenshot" class="modal-image">
            </div>
        </div>
    </div>

    <!-- Pin Achievements Modal -->
    <div id="pinModal" class="pin-modal">
        <div class="pin-modal-content">
            <div class="pin-modal-header">
                <h2>Pinagem de Conquistas</h2>
                <p>Selecione as conquistas que deseja exibir no seu perfil.</p>
            </div>

            <div class="pin-modal-search">
                <div class="pin-search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" id="pinSearchInput" class="pin-search-input" placeholder="Buscar conquistas...">
                </div>
            </div>

            <div class="pin-modal-body" id="pinModalBody">
                <!-- Achievement items will be dynamically inserted here -->
            </div>

            <div class="pin-modal-footer">
                <button class="pin-modal-btn pin-modal-btn-cancel" id="pinCancelBtn">Cancelar</button>
                <button class="pin-modal-btn pin-modal-btn-confirm" id="pinConfirmBtn">Pinar Selecionadas</button>
            </div>
        </div>
    </div>
</body>
</html>