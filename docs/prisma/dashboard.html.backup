<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gaming Dashboard - Prisma</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- CSS Modular -->
    <link rel="stylesheet" href="css/global.css">
    <link rel="stylesheet" href="css/components.css">
    <link rel="stylesheet" href="css/dashboard.css">
    <link rel="stylesheet" href="css/modals.css">
    <link rel="stylesheet" href="css/followers.css">
</head>
<body class="text-gray-100">
        .beam-retro {
            background: radial-gradient(ellipse at center, 
                rgba(212, 160, 23, 0.2) 0%,
                rgba(212, 160, 23, 0.12) 35%,
                rgba(212, 160, 23, 0.04) 55%,
                transparent 70%
            );
            bottom: -30%;
            right: 5%;
            animation: float 22s ease-in-out infinite reverse, pulse 11s ease-in-out infinite;
            animation-delay: 3s;
        }

        /* Prisma center glow - mixing point */
        .prisma-core {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle at center,
                rgba(102, 192, 244, 0.15) 0%,
                rgba(0, 112, 204, 0.1) 25%,
                rgba(16, 124, 16, 0.05) 50%,
                rgba(212, 160, 23, 0.05) 75%,
                transparent 100%
            );
            filter: blur(80px);
            animation: pulse 15s ease-in-out infinite;
        }

        /* Content layer */
        .content-layer {
            position: relative;
            z-index: 1;
        }

        /* Dark overlay for readability */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 14, 20, 0.75);
            z-index: 0;
            pointer-events: none;
        }

        /* Floating particles for prisma effect */
        .prisma-particle {
            position: absolute;
            width: 4px;
            height: 4px;
            border-radius: 50%;
            animation: floatParticle linear infinite;
            opacity: 0;
        }

        @keyframes floatParticle {
            0% {
                transform: translateY(100vh) scale(0);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-100px) scale(1);
                opacity: 0;
            }
        }

        /* Shimmer effect on cards */
        .card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(102, 192, 244, 0.1),
                transparent
            );
            transition: left 0.5s;
        }

        .card:hover::after {
            left: 100%;
        }

        .card {
            position: relative;
            overflow: hidden;
            background: rgba(30, 35, 45, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            transition: all 0.3s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .profile-card {
            background: rgba(30, 35, 45, 0.9);
            border: 2px solid rgba(96, 165, 250, 0.3);
            box-shadow: 
                0 0 20px rgba(102, 192, 244, 0.1),
                inset 0 1px 1px rgba(255, 255, 255, 0.1);
        }

        .profile-card:hover {
            box-shadow: 
                0 0 30px rgba(102, 192, 244, 0.2),
                inset 0 1px 1px rgba(255, 255, 255, 0.15);
        }

        .stat-card {
            background: rgba(20, 25, 35, 0.9);
            box-shadow: 
                0 4px 20px rgba(0, 0, 0, 0.3),
                inset 0 1px 1px rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 
                0 8px 30px rgba(102, 192, 244, 0.15),
                inset 0 1px 1px rgba(255, 255, 255, 0.1);
        }

        .progress-bar {
            height: 6px;
            border-radius: 3px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            transition: width 0.5s ease;
        }

        .game-row {
            transition: all 0.2s ease;
        }

        .game-row:hover {
            background: rgba(96, 165, 250, 0.1);
            transform: translateX(4px);
        }

        .trophy-icon {
            color: #fbbf24;
        }

        .controller-icon {
            color: #60a5fa;
        }

        .users-icon {
            color: #34d399;
        }

        .level-badge {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 600;
        }

        .online-indicator {
            width: 12px;
            height: 12px;
            background: #10b981;
            border-radius: 50%;
            border: 2px solid #0f1419;
            position: absolute;
            bottom: 8px;
            right: 8px;
        }

        .achievement-star {
            color: #9ca3af;
            font-size: 20px;
            transition: color 0.2s ease;
        }

        .achievement-star:hover {
            color: #fbbf24;
        }

        .view-toggle {
            background: rgba(30, 35, 45, 0.6);
            border-radius: 8px;
            padding: 4px;
        }

        .view-toggle button {
            padding: 8px 12px;
            border-radius: 6px;
            transition: all 0.2s ease;
        }

        .view-toggle button.active {
            background: rgba(96, 165, 250, 0.2);
            color: #60a5fa;
        }

        .platform-badge {
            font-size: 11px;
            padding: 4px 8px;
            border-radius: 6px;
            background: rgba(96, 165, 250, 0.1);
            color: #93c5fd;
        }

        .sidebar {
            background: rgba(15, 20, 25, 0.95);
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            z-index: 100;
        }

        .sidebar-icon {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: all 0.2s ease;
            cursor: pointer;
        }

        .sidebar-icon:hover {
            background: rgba(96, 165, 250, 0.1);
        }

        .sidebar-icon.active {
            background: rgba(96, 165, 250, 0.2);
        }

        /* Profile Edit Overlay */
        .profile-avatar-container {
            position: relative;
            cursor: pointer;
        }

        .profile-edit-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .profile-avatar-container:hover .profile-edit-overlay {
            opacity: 1;
        }

        .edit-profile-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .edit-profile-modal.active {
            display: flex;
        }

        .edit-profile-content {
            background: rgba(30, 35, 45, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(96, 165, 250, 0.2);
            border-radius: 24px;
            padding: 32px;
            max-width: 500px;
            width: 100%;
            animation: slideUp 0.3s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .avatar-preview {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid #60a5fa;
            margin: 0 auto 20px;
        }

        .file-input-wrapper {
            position: relative;
            overflow: hidden;
            display: inline-block;
            width: 100%;
        }

        .file-input-wrapper input[type=file] {
            position: absolute;
            left: -9999px;
        }

        .file-input-label {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 24px;
            background: rgba(96, 165, 250, 0.2);
            border: 1px solid #60a5fa;
            border-radius: 12px;
            color: #60a5fa;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .file-input-label:hover {
            background: rgba(96, 165, 250, 0.3);
            transform: translateY(-2px);
        }

        .form-input-profile {
            width: 100%;
            padding: 12px 16px;
            background: rgba(20, 25, 35, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: #e5e7eb;
            font-size: 15px;
            outline: none;
            transition: all 0.3s ease;
        }

        .form-input-profile:focus {
            border-color: rgba(96, 165, 250, 0.5);
            background: rgba(20, 25, 35, 0.8);
            box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
        }

        .game-thumbnail {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            object-fit: cover;
        }

        .completion-circle {
            position: relative;
            width: 60px;
            height: 60px;
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }

        .pulse {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        .gradient-text {
            background: linear-gradient(135deg, #60a5fa 0%, #3b82f6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .table-header {
            color: #9ca3af;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .scrollbar-thin::-webkit-scrollbar {
            width: 6px;
        }

        .scrollbar-thin::-webkit-scrollbar-track {
            background: rgba(30, 35, 45, 0.3);
        }

        .scrollbar-thin::-webkit-scrollbar-thumb {
            background: rgba(96, 165, 250, 0.3);
            border-radius: 3px;
        }

        .scrollbar-thin::-webkit-scrollbar-thumb:hover {
            background: rgba(96, 165, 250, 0.5);
        }

        /* Settings Page Styles */
        .settings-page {
            display: none;
        }

        .settings-page.active {
            display: block;
        }

        .dashboard-page.active {
            display: block;
        }

        .dashboard-page {
            display: none;
        }

        .settings-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 32px;
            padding-bottom: 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .settings-header i {
            color: #10b981;
            font-size: 32px;
        }

        .settings-header h1 {
            font-size: 32px;
            font-weight: 700;
        }

        .settings-card {
            background: rgba(30, 35, 45, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            transition: all 0.3s ease;
        }

        .settings-card:hover {
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        .settings-card-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .settings-card-icon {
            width: 40px;
            height: 40px;
            background: rgba(96, 165, 250, 0.1);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .settings-card-icon.logout {
            background: rgba(34, 197, 94, 0.1);
            color: #22c55e;
        }

        .settings-card-icon.delete {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
        }

        .settings-card h3 {
            font-size: 18px;
            font-weight: 600;
            margin: 0;
        }

        .settings-card p {
            color: #9ca3af;
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 16px;
        }

        .btn-logout {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .btn-logout:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(34, 197, 94, 0.3);
        }

        .btn-delete {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
        }

        /* Followers/Following Page Styles */
        .followers-page {
            display: none;
        }

        .followers-page.active {
            display: block;
        }

        .followers-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
        }

        .followers-header i {
            color: #10b981;
            font-size: 32px;
        }

        .followers-header h1 {
            font-size: 32px;
            font-weight: 700;
        }

        .followers-tabs {
            display: flex;
            gap: 0;
            border-bottom: 2px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 24px;
        }

        .followers-tab {
            padding: 12px 24px;
            background: transparent;
            border: none;
            color: #9ca3af;
            font-weight: 600;
            cursor: pointer;
            position: relative;
            transition: all 0.3s ease;
            font-size: 14px;
        }

        .followers-tab.active {
            color: #60a5fa;
        }

        .followers-tab.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, #60a5fa, #3b82f6);
        }

        .followers-tab:hover {
            color: #93c5fd;
        }

        .followers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 16px;
        }

        .follower-card {
            background: rgba(30, 35, 45, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .follower-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(102, 192, 244, 0.1),
                transparent
            );
            transition: left 0.5s;
        }

        .follower-card:hover::after {
            left: 100%;
        }

        .follower-card:hover {
            transform: translateY(-4px);
            border-color: rgba(96, 165, 250, 0.3);
            box-shadow: 0 8px 20px rgba(96, 165, 250, 0.15);
        }

        .follower-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            margin: 0 auto 12px;
            border: 2px solid rgba(96, 165, 250, 0.3);
            object-fit: cover;
        }

        .follower-name {
            font-weight: 600;
            font-size: 15px;
            margin-bottom: 4px;
            color: #fff;
        }

        .follower-username {
            color: #9ca3af;
            font-size: 13px;
            margin-bottom: 12px;
        }

        .btn-follow {
            background: transparent;
            color: #60a5fa;
            border: 1px solid #60a5fa;
            padding: 8px 16px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 13px;
            width: 100%;
        }

        .btn-follow:hover {
            background: #60a5fa;
            color: white;
        }

        .btn-follow.following {
            background: rgba(96, 165, 250, 0.2);
            color: #60a5fa;
            border-color: #60a5fa;
        }

        .btn-follow.following:hover {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            border-color: #ef4444;
        }

        .btn-follow.following:hover::after {
            content: 'Deixar de seguir';
        }

        .btn-follow.following::after {
            content: 'Seguindo';
        }

        .search-box {
            margin-bottom: 24px;
        }

        .search-input {
            width: 100%;
            background: rgba(30, 35, 45, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 14px 20px;
            color: white;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .search-input:focus {
            outline: none;
            border-color: rgba(96, 165, 250, 0.5);
            box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
        }

        .search-input::placeholder {
            color: #6b7280;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* Pinned Achievements Styles */
        .pinned-achievements {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .pinned-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        .pinned-achievements {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            overflow: visible;
            position: relative;
            z-index: 10;
        }

        .pinned-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        .pinned-achievement {
            background: rgba(96, 165, 250, 0.08);
            border: 1px solid rgba(96, 165, 250, 0.15);
            border-radius: 10px;
            padding: 10px 8px;
            aspect-ratio: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .pinned-achievement:hover {
            background: rgba(96, 165, 250, 0.12);
            border-color: rgba(96, 165, 250, 0.3);
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 8px 24px rgba(96, 165, 250, 0.15);
        }

        .achievement-icon {
            font-size: 28px;
            margin-bottom: 6px;
            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
            flex-shrink: 0;
        }

        .achievement-name {
            font-size: 10px;
            font-weight: 600;
            color: #e5e7eb;
            line-height: 1.25;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            line-clamp: 2;
            -webkit-box-orient: vertical;
            width: 100%;
            padding: 0 4px;
            word-break: break-word;
        }

        .achievement-game {
            display: none;
        }

        /* Achievement Modal */
        .achievement-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.3s ease;
        }

        .achievement-modal.active {
            display: flex;
        }

        .modal-content {
            background: rgba(30, 35, 45, 0.98);
            border: 1px solid rgba(96, 165, 250, 0.3);
            border-radius: 16px;
            padding: 32px;
            max-width: 500px;
            width: 90%;
            position: relative;
            animation: slideUp 0.3s ease;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        @keyframes slideUp {
            from {
                transform: translateY(50px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .modal-close {
            position: absolute;
            top: 16px;
            right: 16px;
            width: 32px;
            height: 32px;
            background: rgba(255, 255, 255, 0.1);
            border: none;
            border-radius: 8px;
            color: #9ca3af;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            font-size: 20px;
        }

        .modal-close:hover {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
        }

        .modal-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 24px;
            padding-bottom: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .modal-icon {
            font-size: 64px;
            filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
        }

        .modal-title-section h2 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 8px;
            color: #fff;
        }

        .modal-game {
            font-size: 14px;
            color: #60a5fa;
            font-weight: 600;
        }

        .modal-body {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .modal-info-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .modal-info-label {
            font-size: 12px;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
            min-width: 100px;
        }

        .modal-info-value {
            font-size: 14px;
            color: #e5e7eb;
            font-weight: 500;
        }

        .rarity-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
        }

        .rarity-common {
            background: rgba(148, 163, 184, 0.2);
            color: #cbd5e1;
        }

        .rarity-uncommon {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
        }

        .rarity-rare {
            background: rgba(59, 130, 246, 0.2);
            color: #3b82f6;
        }

        .rarity-epic {
            background: rgba(168, 85, 247, 0.2);
            color: #a855f7;
        }

        .rarity-legendary {
            background: rgba(234, 179, 8, 0.2);
            color: #eab308;
        }

        .rarity-percentage {
            font-size: 14px;
            font-weight: 700;
        }

        .modal-description {
            background: rgba(20, 25, 35, 0.6);
            padding: 16px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            margin-top: 8px;
        }

        .modal-description p {
            font-size: 13px;
            line-height: 1.6;
            color: #d1d5db;
            margin: 0;
        }

        .modal-image {
            width: 100%;
            height: 200px;
            border-radius: 12px;
            object-fit: cover;
            margin-top: 8px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Tooltip - Remover */
        .pinned-achievement[data-tooltip]::after {
            display: none;
        }

        /* Pin Achievements Modal */
        .pin-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.3s ease;
        }

        .pin-modal.active {
            display: flex;
        }

        .pin-modal-content {
            background: rgba(30, 35, 45, 0.98);
            border: 1px solid rgba(96, 165, 250, 0.3);
            border-radius: 16px;
            padding: 0;
            max-width: 700px;
            width: 90%;
            max-height: 85vh;
            position: relative;
            animation: slideUp 0.3s ease;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            display: flex;
            flex-direction: column;
        }

        .pin-modal-header {
            padding: 24px 32px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .pin-modal-header h2 {
            font-size: 24px;
            font-weight: 700;
            margin: 0 0 8px 0;
            color: #fff;
        }

        .pin-modal-header p {
            font-size: 14px;
            color: #9ca3af;
            margin: 0;
        }

        .pin-modal-search {
            padding: 20px 32px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .pin-search-box {
            position: relative;
        }

        .pin-search-box i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 14px;
        }

        .pin-search-input {
            width: 100%;
            padding: 12px 16px 12px 44px;
            background: rgba(20, 25, 35, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            color: #e5e7eb;
            font-size: 14px;
            outline: none;
            transition: all 0.3s ease;
        }

        .pin-search-input::placeholder {
            color: #6b7280;
        }

        .pin-search-input:focus {
            border-color: rgba(96, 165, 250, 0.5);
            background: rgba(20, 25, 35, 0.8);
        }

        .pin-modal-body {
            padding: 20px 32px;
            overflow-y: auto;
            flex: 1;
        }

        .pin-modal-body::-webkit-scrollbar {
            width: 8px;
        }

        .pin-modal-body::-webkit-scrollbar-track {
            background: rgba(20, 25, 35, 0.4);
        }

        .pin-modal-body::-webkit-scrollbar-thumb {
            background: rgba(96, 165, 250, 0.3);
            border-radius: 4px;
        }

        .pin-modal-body::-webkit-scrollbar-thumb:hover {
            background: rgba(96, 165, 250, 0.5);
        }

        .pin-achievement-item {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px;
            background: rgba(20, 25, 35, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            margin-bottom: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .pin-achievement-item:hover {
            background: rgba(20, 25, 35, 0.6);
            border-color: rgba(96, 165, 250, 0.3);
        }

        .pin-achievement-item.selected {
            background: rgba(96, 165, 250, 0.1);
            border-color: rgba(96, 165, 250, 0.5);
        }

        .pin-checkbox {
            width: 20px;
            height: 20px;
            border: 2px solid rgba(96, 165, 250, 0.3);
            border-radius: 6px;
            background: transparent;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }

        .pin-achievement-item.selected .pin-checkbox {
            background: #3b82f6;
            border-color: #3b82f6;
        }

        .pin-checkbox i {
            color: #fff;
            font-size: 12px;
            display: none;
        }

        .pin-achievement-item.selected .pin-checkbox i {
            display: block;
        }

        .pin-achievement-icon-wrapper {
            width: 48px;
            height: 48px;
            background: rgba(96, 165, 250, 0.1);
            border: 1px solid rgba(96, 165, 250, 0.2);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0;
        }

        .pin-achievement-info {
            flex: 1;
            min-width: 0;
        }

        .pin-achievement-title {
            font-size: 15px;
            font-weight: 600;
            color: #e5e7eb;
            margin-bottom: 4px;
        }

        .pin-achievement-desc {
            font-size: 13px;
            color: #9ca3af;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .pin-modal-footer {
            padding: 20px 32px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            gap: 12px;
            justify-content: flex-end;
        }

        .pin-modal-btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            outline: none;
        }

        .pin-modal-btn-cancel {
            background: rgba(255, 255, 255, 0.05);
            color: #e5e7eb;
        }

        .pin-modal-btn-cancel:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .pin-modal-btn-confirm {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
            color: #fff;
        }

        .pin-modal-btn-confirm:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.3);
        }

        .pin-modal-btn-confirm:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .pin-achievement-empty {
            text-align: center;
            padding: 40px 20px;
            color: #6b7280;
        }

        .pin-achievement-empty i {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        .pinned-achievements {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            overflow: visible;
        }

        .pinned-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            overflow: visible;
        }
    </style>
</head>
<body class="text-gray-100">
